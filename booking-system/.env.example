# ============================================================
# 立欣診所預約系統 環境變數範本
# 複製為 .env（本機）或於部署平台設定；所有密鑰不得寫入程式碼或版控
# ============================================================

# PostgreSQL 連線（Docker Compose 預設值見 docker-compose.yml）
DATABASE_URL="postgresql://lihsin:CHANGE_ME_DB_PASSWORD@db:5432/lihsin_booking"

# Session 簽章密鑰（隨機 32+ 字元；洩漏須立即更換）
SESSION_SECRET="CHANGE_ME_RANDOM_32_CHARS_MIN"

# 個資加密金鑰（32+ 字元）：證件號 AES-256-GCM 加密用
# ⚠️ 一旦有正式資料後不可更換，否則舊資料無法解密；請離線備份保存
PII_ENCRYPTION_KEY="CHANGE_ME_RANDOM_48_CHARS"

# 個資雜湊金鑰（16+ 字元）：證件號查詢索引 HMAC 用，同樣不可事後更換
PII_HASH_KEY="CHANGE_ME_RANDOM_32_CHARS"

# 對外網址（LINE OAuth redirect 用，不含結尾斜線）
APP_BASE_URL="https://booking.lhpedclinic.com.tw"

# 時區固定台灣
TZ="Asia/Taipei"

# ── LINE（由診所自有的 LINE Developers 帳號建立，設定步驟見 docs/05）──
# 留空 = 停用 LINE 功能，前台自動改用手機驗證碼＋簡訊
LINE_LOGIN_CHANNEL_ID=""
LINE_LOGIN_CHANNEL_SECRET=""
LINE_MESSAGING_CHANNEL_ACCESS_TOKEN=""
LINE_MESSAGING_CHANNEL_SECRET=""
# 前台顯示的 LINE 官方帳號加好友連結
NEXT_PUBLIC_LINE_OA_URL=""

# ── 簡訊供應商（可替換模組）──
# console = 開發用（印到伺服器 log，不實際發送）
# mitake = 三竹資訊；every8d = 互動資通
SMS_PROVIDER="console"
SMS_API_USERNAME=""
SMS_API_PASSWORD=""

# ── Docker Compose 專用（app 服務不讀取）──
POSTGRES_PASSWORD="CHANGE_ME_DB_PASSWORD"

# ── seed 測試資料的預設密碼（僅測試環境使用）──
# SEED_ADMIN_PASSWORD=""
# SEED_STAFF_PASSWORD=""
